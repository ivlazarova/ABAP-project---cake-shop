START-OF-SELECTION.
  IF rb_view = 'X'.
    WRITE: / '==============================================================================================================================='.
    WRITE: / '                          Cake catalog'.
    WRITE: / '==============================================================================================================================='.
    LOOP AT gt_cakes INTO ls_cake.
      WRITE / |ID: { ls_cake-cake_id } |.
      WRITE / |Name: { ls_cake-name } |.
      WRITE / |Type: { ls_cake-type } |.
      WRITE / |Description: { ls_cake-description }| .
      WRITE / |Price for 8 pieces: { ls_cake-price } { gc_currency }| .
      WRITE / |Price for 16 pieces: { ls_cake-price * 2 DECIMALS = 2 } { gc_currency }| .
      WRITE / |Quantity: { ls_cake-quantity }| .
      WRITE /.
    ENDLOOP.

  ELSEIF rb_order = 'X'.
    CLEAR gt_cake_ids.
    SPLIT p_cakes AT ',' INTO TABLE DATA(lt_cake_strings).

    LOOP AT lt_cake_strings INTO DATA(lv_cake_string).
      IF lv_cake_string IS NOT INITIAL.
        gv_cake_id = lv_cake_string.
        APPEND gv_cake_id TO gt_cake_ids.
      ENDIF.
    ENDLOOP.
    READ TABLE gt_customers INTO ls_customer WITH KEY customer_id = p_cus_id.
    IF sy-subrc <> 0.
      ls_customer-customer_id = p_cus_id.
      ls_customer-name = p_f_name.
      ls_customer-last_name = p_l_name.
      ls_customer-phone = p_phone.
      ls_customer-email = p_email.
      INSERT ls_customer INTO TABLE gt_customers.
      IF sy-subrc = 0.
        WRITE |New customer added: { p_f_name } { p_l_name }|.
      ENDIF.
    ELSE.
      WRITE |Customer found: { ls_customer-name } { ls_customer-last_name }|.
    ENDIF.

    gv_order_count += 1.

    ls_order-order_id = gv_order_count.
    ls_order-customer_id = p_cus_id.
    ls_order-order_date = sy-datum.
    ls_order-status = 'New'.
    ls_order-total_cost = 0.
    WRITE / |================================|.
    WRITE / |Order id: { ls_order-order_id }|.
    WRITE / |================================|.

    LOOP AT gt_cake_ids INTO DATA(lv_id_string).
  gv_cake_id = lv_id_string.
  READ TABLE gt_cakes INTO ls_cake WITH KEY cake_id = gv_cake_id.
  IF sy-subrc = 0.
    IF ls_cake-quantity > 0.

      ls_order_item-order_id = gv_order_count.
      ls_order_item-cake_id = gv_cake_id.

      IF rb_pc8 = 'X'.
        ls_order_item-pieces = 8.
        gv_cake_price = ls_cake-price.
      ELSEIF rb_pc16 = 'X'.
        ls_order_item-pieces = 16.
        gv_cake_price = ls_cake-price * 2.
      ENDIF.
      ls_order-total_cost += gv_cake_price.
      gv_cake_count += 1.

      INSERT ls_order_item INTO TABLE gt_order_items.

      ls_cake-quantity -= 1.
      MODIFY TABLE gt_cakes FROM ls_cake.

      WRITE / |Cake: { ls_cake-name }|.
      WRITE / |Pieces: { ls_order_item-pieces }|.
      WRITE / |Price: { ls_order-total_cost DECIMALS = 2 } { gc_currency }|.
      WRITE /.

    ELSE.
      WRITE / |Cake { ls_cake-name } is out of stock.|.
      WRITE /.
    ENDIF.
  ELSE.
    WRITE / |Cake ID { gv_cake_id } not found.|.
    WRITE /.
  ENDIF.
ENDLOOP.

    IF gt_order_items IS NOT INITIAL.
      READ TABLE gt_order_items INTO ls_order_item INDEX 1.
      ls_order_item-inscription = p_inscr.
      ls_order_item-candles = p_cand.
      ls_order_item-fountain = p_fount.
      MODIFY gt_order_items FROM ls_order_item INDEX 1.
    ENDIF.

    IF p_inscr IS NOT INITIAL.
      ls_order-total_cost += gc_inscription_price.
    ENDIF.

    IF p_cand > 0.
      ls_order-total_cost += p_cand * gc_candle_price.
    ENDIF.

    IF p_fount > 0.
      ls_order-total_cost += p_fount * gc_fountain_price.
    ENDIF.

    IF gv_cake_count >= 15.
      gv_discount_percent = 15.
      gv_discount_amount = ls_order-total_cost * '0.15'.
    ELSEIF gv_cake_count >= 5.
      gv_discount_percent = 10.
      gv_discount_amount = ls_order-total_cost * '0.10'.
    ELSEIF gv_cake_count >= 3.
      gv_discount_percent = 5.
      gv_discount_amount = ls_order-total_cost * '0.05'.
    ELSE.
      gv_discount_percent = 0.
      gv_discount_amount = ls_order-total_cost.
    ENDIF.

    ls_order-discount = gv_discount_amount.
ls_order-total_cost -= gv_discount_amount.

    INSERT ls_order INTO TABLE gt_orders.

    WRITE / |=============================|.
    WRITE / |Inscription: { ls_order_item-inscription }|.
    WRITE / |Candles: { ls_order_item-candles }|.
    WRITE / |Fountain candles: { ls_order_item-fountain }|.
    WRITE / |Discount ({ gv_discount_percent })% (-{ gv_discount_amount DECIMALS = 2 } { gc_currency })|.
    WRITE / |Total cost: { ls_order-total_cost DECIMALS = 2 } { gc_currency }|.
    WRITE / |Order date: { ls_order-order_date DATE = USER }|.

  ELSEIF rb_canc = 'X'.
    WRITE / |Order cancelled.|.

  ENDIF.
