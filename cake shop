REPORT zil_cake_shop.

TYPES: BEGIN OF ty_cake,
         cake_id     TYPE n LENGTH 8,
         name        TYPE c LENGTH 250,
         type        TYPE c LENGTH 250,
         description TYPE c LENGTH 250,
         price       TYPE p DECIMALS 2,
         quantity    TYPE i,
         currency    TYPE c LENGTH 5,
       END OF ty_cake.

TYPES: BEGIN OF ty_order_items,
         order_id    TYPE n LENGTH 8,
         cake_id     TYPE n LENGTH 8,
         inscription TYPE c LENGTH 50,
         candles     TYPE i,
         fountain    TYPE i,
         quantity    TYPE i,
         pieces      TYPE i,
       END OF ty_order_items.

CONSTANTS: gc_currency          TYPE c LENGTH 5 VALUE 'EUR',
           gc_inscription_price TYPE p DECIMALS 2 VALUE '5.00',
           gc_candle_price      TYPE p DECIMALS 2 VALUE '1.20',
           gc_fountain_price    TYPE p DECIMALS 2 VALUE '2.50'.

TYPES: BEGIN OF ty_customer,
         customer_id TYPE n LENGTH 10,
         name        TYPE c LENGTH 250,
         last_name   TYPE c LENGTH 250,
         phone       TYPE c LENGTH 250,
         email       TYPE c LENGTH 250,
       END OF ty_customer.

TYPES: BEGIN OF ty_order,
         order_id    TYPE i,
         customer_id TYPE n LENGTH 10,
         order_date  TYPE d,
         pickup_date TYPE d,
         total_cost  TYPE p DECIMALS 2,
         discount    TYPE p DECIMALS 2,
         status      TYPE c LENGTH 250,
       END OF ty_order.

TYPES: tt_cakes       TYPE SORTED TABLE OF ty_cake WITH UNIQUE KEY cake_id,
       tt_orders      TYPE SORTED TABLE OF ty_order WITH UNIQUE KEY order_id,
       tt_order_items TYPE STANDARD TABLE OF ty_order_items WITH NON-UNIQUE KEY order_id cake_id,
       tt_customers   TYPE SORTED TABLE OF ty_customer WITH UNIQUE KEY customer_id.

DATA: gt_cakes       TYPE tt_cakes,
      gt_orders      TYPE tt_orders,
      gt_order_items TYPE tt_order_items,
      gt_customers   TYPE tt_customers.

DATA: ls_cake       TYPE ty_cake,
      ls_order      TYPE ty_order,
      ls_order_item TYPE ty_order_items,
      ls_customer   TYPE ty_customer.

DATA: gv_order_count      TYPE i VALUE 0,
      gt_total_price      TYPE p DECIMALS 2,
      gv_error            TYPE c LENGTH 1,
      gt_cake_ids         TYPE STANDARD TABLE OF string WITH DEFAULT KEY,
      gv_cake_id          TYPE n LENGTH 8,
      gv_cake_count       TYPE i,
      gv_discount_percent TYPE p DECIMALS 2 VALUE 0,
      gv_discount_amount  TYPE p DECIMALS 2 VALUE 0,
      gv_cake_price type p DECIMALS 2.
.

SELECTION-SCREEN BEGIN OF BLOCK b1 WITH FRAME TITLE TEXT-001.
  PARAMETERS: p_cus_id TYPE n LENGTH 10 OBLIGATORY,
              p_f_name TYPE c LENGTH 250,
              p_l_name TYPE c LENGTH 250,
              p_phone  TYPE c LENGTH 250,
              p_email  TYPE c LENGTH 250.
SELECTION-SCREEN END OF BLOCK b1.

SELECTION-SCREEN BEGIN OF BLOCK b2 WITH FRAME TITLE TEXT-002.
  PARAMETERS: rb_view  RADIOBUTTON GROUP grp1 DEFAULT 'X',
              rb_order RADIOBUTTON GROUP grp1,
              rb_canc  RADIOBUTTON GROUP grp1.
SELECTION-SCREEN END OF BLOCK b2.

SELECTION-SCREEN BEGIN OF BLOCK b3 WITH FRAME TITLE TEXT-003.

  SELECTION-SCREEN COMMENT /1(75) TEXT-005.
  PARAMETERS: p_cakes TYPE string LOWER CASE.
  PARAMETERS: p_inscr TYPE c LENGTH 250,
              p_cand  TYPE i,
              p_fount TYPE i.
SELECTION-SCREEN END OF BLOCK b3.

SELECTION-SCREEN BEGIN OF BLOCK b4 WITH FRAME TITLE TEXT-004.
  PARAMETERS: rb_pc8  RADIOBUTTON GROUP grp2 DEFAULT 'X',
              rb_pc16 RADIOBUTTON GROUP grp2.
SELECTION-SCREEN END OF BLOCK b4.

AT SELECTION-SCREEN.
  CLEAR gv_error.

  IF p_cus_id IS INITIAL.
    MESSAGE 'Enter customer ID!' TYPE 'E'.
  ENDIF.

  IF rb_order = 'X'.
    IF p_cakes IS INITIAL.
      MESSAGE 'Enter at least one cake ID' TYPE 'E'.
    ENDIF.
  ENDIF.


